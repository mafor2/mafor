ORGANIC%gamma_oc4(1)=0.00
! fraction of oc4 in mode NA
ORGANIC%gamma_oc4(2)=0.00
! fraction of oc4 in mode AI
ORGANIC%gamma_oc4(3)=0.00
! fraction of oc4 in mode AS
ORGANIC%gamma_oc4(4)=0.00
! fraction of oc4 in mode CS
ORGANIC%gamma_oc4(5)=0.00

! fraction of oc5 in mode NU
ORGANIC%gamma_oc5(1)=0.00
! fraction of oc5 in mode NA
ORGANIC%gamma_oc5(2)=0.00
! fraction of oc5 in mode AI
ORGANIC%gamma_oc5(3)=0.00
! fraction of oc5 in mode AS
ORGANIC%gamma_oc5(4)=0.00
! fraction of oc5 in mode CS
ORGANIC%gamma_oc5(5)=0.00

! fraction of oc6 in mode NU
ORGANIC%gamma_oc6(1)=0.00
! fraction of oc6 in mode NA
ORGANIC%gamma_oc6(2)=0.00
! fraction of oc6 in mode AI
ORGANIC%gamma_oc6(3)=0.00
! fraction of oc6 in mode AS
ORGANIC%gamma_oc6(4)=0.00
! fraction of oc6 in mode CS
ORGANIC%gamma_oc6(5)=0.00

! fraction of oc7 in mode NU
ORGANIC%gamma_oc7(1)=0.00
! fraction of oc7 in mode NA
ORGANIC%gamma_oc7(2)=0.00
! fraction of oc7 in mode AI
ORGANIC%gamma_oc7(3)=0.00
! fraction of oc7 in mode AS
ORGANIC%gamma_oc7(4)=0.00
! fraction of oc7 in mode CS
ORGANIC%gamma_oc7(5)=0.00

! fraction of oc8 in mode NU
ORGANIC%gamma_oc8(1)=0.00
! fraction of oc8 in mode NA
ORGANIC%gamma_oc8(2)=0.00
! fraction of oc8 in mode AI
ORGANIC%gamma_oc8(3)=0.00
! fraction of oc8 in mode AS
ORGANIC%gamma_oc8(4)=0.00
! fraction of oc8 in mode CS
ORGANIC%gamma_oc8(5)=0.00

! fraction of oc9 in mode NU
ORGANIC%gamma_oc9(1)=0.00
! fraction of oc9 in mode NA
ORGANIC%gamma_oc9(2)=0.00
! fraction of oc9 in mode AI
ORGANIC%gamma_oc9(3)=0.00
! fraction of oc9 in mode AS
ORGANIC%gamma_oc9(4)=0.00
! fraction of oc9 in mode CS
ORGANIC%gamma_oc9(5)=0.00


! Kinetic parameters
! only change for sensitivity tests
! scaling factor activation energy of CH3SO2 decomposition
fch3so2=0.90
!below factors are not active
! scaling factor for aqueous-phase reaction MSIA + O3
!fmsiao3=1.00
! scaling factor for rate constant I2O + I
!fi2oi=1.00
! scaling factor for rate constant OIO + OH
!foiooh=1.00
! scaling factor for aqueous phase reduction of IO3 by H2O2
!fio3red=1.00
/
