! fraction of oc3 in mode AI
ORGANIC%gamma_oc3(3)=0.00
! fraction of oc3 in mode AS
ORGANIC%gamma_oc3(4)=0.00
! fraction of oc3 in mode CS
ORGANIC%gamma_oc3(5)=0.00

